  <!-- ════ Part 05: Process Lifecycle ════ -->
  <section class="section" id="process">
    <div class="section-label">Part 05 · 流程生命周期</div>
    <div class="section-title">从需求创建到报告导出的 5 个固定节点</div>
    <div class="section-copy">每个节点都有固定的写入位置和产出物，不再靠"手写步骤文档"驱动。需求一创建就得到完整模板，人工只维护固定字段，系统派生所有报告。</div>

    <div class="process-timeline">
      <div class="process-step">
        <div class="process-step-icon">📥</div>
        <h4>创建收编</h4>
        <p>create_workstream 自动生成 meta.json + CSV + 核心文档模板 + 工作站入口</p>
      </div>
      <div class="process-step">
        <div class="process-step-icon">🧱</div>
        <h4>结构化沉淀</h4>
        <p>用例行、生命周期字段、ATP 绑定折叠为同一份 workstream 对象</p>
      </div>
      <div class="process-step">
        <div class="process-step-icon">🔁</div>
        <h4>ATP 快照</h4>
        <p>rootCaseId 1 层归桶 + 同 taskId 级联刷新，scope_summary 并存</p>
      </div>
      <div class="process-step">
        <div class="process-step-icon">🔍</div>
        <h4>评审分析</h4>
        <p>自动化卡点 tab 暴露缺口，ATP 命中分析给出真实执行数据</p>
      </div>
      <div class="process-step">
        <div class="process-step-icon">📊</div>
        <h4>报告导出</h4>
        <p>右侧报告一键复制，日报/周报由工作站生成草稿，人工只补判断</p>
      </div>
    </div>

    <div class="bento-grid-3" style="margin-top: 24px;">
      <div class="bento-card">
        <div class="bento-icon teal">🏗️</div>
        <h3>模板化创建</h3>
        <p>create_workstream 直接生成完整模板：meta.json、主 CSV、01~04 文档、artifacts 目录、工作站入口注册。</p>
      </div>
      <div class="bento-card">
        <div class="bento-icon amber">📝</div>
        <h3>字段驱动，不再写文档</h3>
        <p>人工维护 6 个固定字段（目标/进展/阻塞/归因/下一步/依赖），系统派生详情页、日报、周报。</p>
      </div>
      <div class="bento-card">
        <div class="bento-icon violet">📤</div>
        <h3>报告生成制</h3>
        <p>日报草稿从 active workstream 的 notes + ATP 快照自动聚合；周报草稿从覆盖率变化 + 风险项生成。</p>
      </div>
    </div>
  </section>

  <!-- ════ Part 06: Governance Roadmap ════ -->
  <section class="section" id="governance">
    <div class="section-label">Part 06 · 治理路线</div>
    <div class="section-title">P0 收口规则 → P1 流程入口 → P2 历史迁移</div>
    <div class="section-copy">不画完整 roadmap，只按优先级列出三个阶段。P0 先定规则不动历史目录，P1 把工作站变成真正的流程入口，P2 逐步迁移遗留结构。</div>

    <div class="roadmap-grid">
      <div class="roadmap-card p0">
        <div class="roadmap-priority">P0 · 先收口规则</div>
        <h4>不动历史目录，先明确边界</h4>
        <ul>
          <li>更新 PROJECT_STRUCTURE.md 反映当前架构</li>
          <li>创建单一真相矩阵（truth_matrix.md）</li>
          <li>明确 workstream 最小合同</li>
          <li>明确 sandbox 使用边界</li>
          <li>日报/周报改为工作站生成草稿</li>
        </ul>
      </div>
      <div class="roadmap-card p1">
        <div class="roadmap-priority">P1 · 流程入口</div>
        <h4>工作站成为唯一人工门户</h4>
        <ul>
          <li>create_workstream 生成完整模板</li>
          <li>增加日报/周报草稿生成按钮</li>
          <li>需求级 HTML + 跨需求手册纳入工作站索引</li>
          <li>station_catalog.json 统一管理工具页清单</li>
        </ul>
      </div>
      <div class="roadmap-card p2">
        <div class="roadmap-priority">P2 · 历史迁移</div>
        <h4>逐步收敛遗留结构</h4>
        <ul>
          <li>停止新增自由命名版本目录</li>
          <li>跨需求手册从 archive/ 迁到 knowledge/</li>
          <li>清理 sandbox 长驻文件</li>
          <li>workspace/report → workspace/reports 统一</li>
        </ul>
      </div>
    </div>
  </section>

  <footer class="footer">
    这个页面呈现 caseHelper 从脚本仓库到服务化工作站的演进全景。六个层面——三层架构、数据真相、资产治理、工作站门户、流程生命周期、治理路线——构成了当前系统的完整叙事。
  </footer>

  <script>
    /* ── Architecture interactive layers ── */
    var archLayers = [
      {
        id: "station",
        icon: "🖥️",
        name: "Station — 工作站门户",
        desc: "唯一人工入口，三栏布局，调用 services 完成所有操作",
        count: "1 portal",
        details: [
          "三栏布局：左侧需求导航（版本筛选 + 置顶 + 搜索）+ 中间多 tab + 右侧总结报告",
          "board_state.json 存储 ATP 绑定、快照、UI 状态",
          "dashboard_data.json 存储聚合仪表盘数据",
          "跨需求工具页：AC 认证工具、文档查看器、工具汇总"
        ],
        tags: ["index.html", "board_state.json", "dashboard_data.json"]
      },
      {
        id: "services",
        icon: "⚙️",
        name: "Services — 统一编排层",
        desc: "跨 skill 业务编排，所有方法返回 ServiceResult",
        count: "19+ services",
        details: [
          "interactive_station_service — 工作站后端主服务",
          "workstream_orchestrator_service — 需求创建/迁移/归档",
          "sdet_atp_task_read_service + atp_root_scope_aggregator — ATP 数据读取与 scope 聚合",
          "case_analysis_service + analysis_writeback_service — 用例分析与回写",
          "lark_writeback_service + feishu_csv_sheet_import_service — 飞书读写",
          "ac_auth_switch_service — AC 认证源切换",
          "统一基础设施：config.py / errors.py / result.py / logging_config.py"
        ],
        tags: ["ServiceResult", "ErrorCode", "get_config()"]
      },
      {
        id: "scripts",
        icon: "📜",
        name: "Scripts — 薄入口",
        desc: "参数解析 + 调 service + 打印摘要，禁止直接调 skill",
        count: "5 类脚本",
        details: [
          "create/ — 批量创建目录与用例",
          "update/ — 更新用例名称等",
          "sync/ — 同步知识库、回写飞书、同步目录",
          "analyze/ — 分析用例分布、生成概览",
          "station/ — 工作站启动、ATP 回填、数据规范化"
        ],
        tags: ["create", "update", "sync", "analyze", "station"]
      },
      {
        id: "skills",
        icon: "🧩",
        name: "Skills — 单能力封装",
        desc: "底层 API 封装，每个 skill 包含 SKILL.md",
        count: "11 组能力",
        details: [
          "飞书：Token 获取 / API 助手 / 表格查询 / 读取 / 写入",
          "SDET 平台：客户端 / 批量建用例 / 审计修复 / ID 回写 / 登录",
          "用例分析：AI 概述",
          "工作站：station-workbench / workstream-orchestrator",
          "审计：wireless-switch-auditor",
          "SOP：phase0-sop（批量操作门禁）"
        ],
        tags: ["PlatformClient", "LarkSheetReader", "Phase0 SOP"]
      },
      {
        id: "knowledge",
        icon: "📚",
        name: "Knowledge — 知识库与治理",
        desc: "公共步骤、规则资产、治理规范、审计配置",
        count: "100+ cases",
        details: [
          "workstream_index.json — 活跃需求入口索引",
          "common_cases/ — 100+ 公共步骤 JSON",
          "common_cases_manifest.json — 别名到 case_id 映射",
          "governance/ — 真相矩阵 + 需求目录合同",
          "sdet-api-docs/ — SDET 平台 API 文档",
          "audit/ — 审计规则配置"
        ],
        tags: ["truth_matrix.md", "workstream_contract.md", "manifest"]
      }
    ];

    var archState = { activeId: "station" };

    function renderArch() {
      var container = document.getElementById("archLayers");
      var selected = null;
      for (var i = 0; i < archLayers.length; i++) {
        if (archLayers[i].id === archState.activeId) { selected = archLayers[i]; break; }
      }
      if (!selected) selected = archLayers[0];

      container.innerHTML = archLayers.map(function(layer) {
        return '<div class="arch-layer ' + (layer.id === archState.activeId ? 'active' : '') + '" data-layer-id="' + layer.id + '">' +
          '<div class="arch-layer-icon">' + layer.icon + '</div>' +
          '<div class="arch-layer-info">' +
            '<div class="arch-layer-name">' + esc(layer.name) + '</div>' +
            '<div class="arch-layer-desc">' + esc(layer.desc) + '</div>' +
          '</div>' +
          '<div class="arch-layer-count">' + esc(layer.count) + '</div>' +
        '</div>';
      }).join("");

      document.getElementById("archDetailTitle").textContent = selected.name;
      document.getElementById("archDetailList").innerHTML = selected.details.map(function(d) {
        return '<li>' + esc(d) + '</li>';
      }).join("");
      document.getElementById("archDetailTags").innerHTML = selected.tags.map(function(t, i) {
        var cls = ["teal", "amber", "violet"][i % 3];
        return '<div class="tag ' + cls + '">' + esc(t) + '</div>';
      }).join("");

      container.querySelectorAll("[data-layer-id]").forEach(function(node) {
        node.addEventListener("click", function() {
          archState.activeId = node.dataset.layerId;
          renderArch();
        });
      });
    }

    function esc(v) {
      return String(v == null ? "" : v)
        .replace(/&/g, "&amp;").replace(/</g, "&lt;")
        .replace(/>/g, "&gt;").replace(/"/g, "&quot;");
    }

    function revealSections() {
      var sections = document.querySelectorAll('.hero, .section');
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) entry.target.classList.add('visible');
        });
      }, { threshold: 0.12 });
      sections.forEach(function(section) { observer.observe(section); });
    }

    renderArch();
    revealSections();
  </script>
</body>
</html>
